{
  "name": "@prost/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "prisma:seed": "dotenv -e ../../.env -- tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11",
    "@nestjs/config": "^4",
    "@nestjs/core": "^11",
    "@nestjs/jwt": "^10",
    "@nestjs/platform-express": "^11",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^6",
    "@prost/shared-types": "workspace:*",
    "@prost/utils": "workspace:*",
    "bcrypt": "^5",
    "class-transformer": "^0.5",
    "class-validator": "^0.14",
    "node-sql-parser": "^5.4.0",
    "openai": "^6.42.0",
    "pg": "^8",
    "reflect-metadata": "^0.2",
    "rxjs": "^7"
  },
  "devDependencies": {
    "@nestjs/cli": "^11",
    "@types/bcrypt": "^5",
    "@types/express": "^5",
    "@types/node": "^22",
    "@types/pg": "^8",
    "dotenv-cli": "^7",
    "prisma": "^6",
    "tsx": "^4",
    "typescript": "^5",
    "vitest": "^2"
  }
}

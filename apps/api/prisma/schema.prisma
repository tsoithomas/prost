generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  connections   Connection[]
  queryHistory  QueryHistory[]
  snippets      Snippet[]
  preference    UserPreference?
  llmEndpoints  LlmEndpoint[]
  conversations Conversation[]

  @@map("users")
}

model Connection {
  id                   String   @id @default(uuid())
  userId               String
  name                 String
  engine               String   @default("postgres")
  host                 String
  port                 Int
  database             String
  username             String
  encryptedCredentials Json
  sslEnabled           Boolean  @default(false)
  sslRejectUnauthorized Boolean @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  queryHistory  QueryHistory[]
  conversations Conversation[]

  @@map("connections")
}

model QueryHistory {
  id           String   @id @default(uuid())
  userId       String
  connectionId String
  sql          String
  starred      Boolean  @default(false)
  label        String?
  executedAt   DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  connection Connection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([userId, executedAt])
  @@map("query_history")
}

model Snippet {
  id        String   @id @default(uuid())
  userId    String
  name      String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@map("snippets")
}

model LlmEndpoint {
  id              String   @id @default(uuid())
  userId          String
  name            String
  baseUrl         String
  encryptedApiKey Json
  // SQLite has no scalar-list type; stored as a JSON-encoded string array. The
  // LlmEndpointService (de)serializes it so the external `models: string[]` contract is unchanged.
  models          String
  // Optional per-endpoint overrides for the AI context/output budgets. Null → fall back to the
  // env default (AI_CONTEXT_BUDGET_CHARS / AI_MAX_OUTPUT_TOKENS). `contextBudget` is in characters.
  contextBudget   Int?
  maxOutputTokens Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("llm_endpoints")
}

// Persisted AI chat threads (Phase AI-improvement #6). App-DB only (principle §1) — stores the
// conversation text, never target-DB rows. User-scoped and ownership-checked like QueryHistory.
model Conversation {
  id           String   @id @default(uuid())
  userId       String
  connectionId String
  title        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user       User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  connection Connection            @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  messages   ConversationMessage[]

  @@index([userId, connectionId, updatedAt])
  @@map("conversations")
}

model ConversationMessage {
  id             String   @id @default(uuid())
  conversationId String
  // Mirrors ChatRole ('user' | 'assistant') from @prost/shared-types.
  role           String
  content        String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("conversation_messages")
}

model UserPreference {
  userId String @id

  // Mirrors ColorMode ('light' | 'dark' | 'system') from @prost/shared-types.
  colorMode   String @default("system")
  accentColor String @default("#498fff")

  // FontSize ('sm' | 'md' | 'lg') / GridDensity ('compact' | 'normal' | 'comfortable').
  fontSize    String @default("md")
  gridDensity String @default("normal")

  // SQLite has no JSON type — these hold JSON-stringified structures (see @prost/shared-types):
  //   keybindings           -> KeybindingMap                          (actionId -> chord, overrides only)
  //   customPalettes        -> CustomPalette[]
  //   connectionOverrides   -> Record<connectionId, ConnectionThemeOverride>
  //   columnRenderOverrides -> ColumnRenderOverrides                  (connectionId -> "schema.table" -> column -> mode)
  keybindings           String @default("{}")
  customPalettes        String @default("[]")
  connectionOverrides   String @default("{}")
  columnRenderOverrides String @default("{}")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

# --- Prost application database (Prisma) ---
# docker-compose maps prost-postgres to host port 5433
DATABASE_URL="postgresql://prost:prost@localhost:5433/prost"

# --- Auth ---
JWT_SECRET="change-me-to-a-long-random-string"

# --- Seeded admin user (apps/api/prisma/seed.ts) ---
ADMIN_EMAIL="admin@prost.local"
ADMIN_PASSWORD="change-me"

# --- Target-DB credential encryption (AES-256-GCM) ---
# 32 random bytes, base64-encoded, e.g.: openssl rand -base64 32
CREDENTIAL_ENCRYPTION_KEY="REPLACE_WITH_32_BYTE_BASE64_KEY"

# --- Target query timeout (ms), applied via statement_timeout ---
QUERY_TIMEOUT_MS=30000

# --- API server ---
PORT=3001

# --- CORS: comma-separated list of origins allowed to call the API ---
WEB_ORIGIN="http://localhost:5173"

# --- Demo target database (docker-compose: demo-target-postgres, host port 5434) ---
# Not used by the app directly; convenient for manually creating a test connection.
DEMO_TARGET_DATABASE_URL="postgresql://demo:demo@localhost:5434/demo"

# --- Frontend (apps/web) ---
# Base URL the SPA uses to reach the NestJS API. Read at dev/build time by Vite.
VITE_API_URL="http://localhost:3001"

# --- AI ---
# LLM endpoints are managed per-user inside the app; no AI env vars required.

# --- Prost application database (Prisma, SQLite) ---
# File-based; path is resolved relative to apps/api/prisma/. No docker service needed.
DATABASE_URL="file:./data/prost.db"

# --- Auth ---
JWT_SECRET="change-me-to-a-long-random-string"

# --- Seeded admin user (apps/api/prisma/seed.ts) ---
ADMIN_EMAIL="admin@prost.local"
ADMIN_PASSWORD="change-me"

# --- Target-DB credential encryption (AES-256-GCM) ---
# 32 random bytes, base64-encoded, e.g.: openssl rand -base64 32
CREDENTIAL_ENCRYPTION_KEY="REPLACE_WITH_32_BYTE_BASE64_KEY"

# --- Target query timeout (ms), applied via statement_timeout ---
QUERY_TIMEOUT_MS=30000

# --- API server ---
PORT=3001

# --- CORS: comma-separated list of origins allowed to call the API ---
WEB_ORIGIN="http://localhost:5173"

# --- Demo target databases (docker-compose: demo-target-postgres :5434, demo-target-mysql :3307) ---
# Not used by the app directly; convenient for manually creating a test connection.
DEMO_TARGET_DATABASE_URL="postgresql://demo:demo@localhost:5434/demo"
DEMO_TARGET_MYSQL_DATABASE_URL="mysql://demo:demo@localhost:3307/demo"

# --- Driver contract tests (apps/api/.../*-driver.contract.test.ts) ---
# Live PostgreSQL/MySQL targets the conformance suite connects to. When unset, the suite
# uses the docker-compose defaults below and skips itself if the server is unreachable.
# Set REQUIRE_LIVE_DRIVER_CONTRACTS=true (CI) to fail instead of skip when a live engine is down.
# CONTRACT_PG_HOST=localhost
# CONTRACT_PG_PORT=5434
# CONTRACT_MYSQL_HOST=localhost
# CONTRACT_MYSQL_PORT=3307
# REQUIRE_LIVE_DRIVER_CONTRACTS=true

# --- Frontend (apps/web) ---
# Base URL the SPA uses to reach the NestJS API. Read at dev/build time by Vite.
VITE_API_URL="http://localhost:3001"

# --- AI ---
# LLM endpoints are managed per-user inside the app; no AI env vars required.
